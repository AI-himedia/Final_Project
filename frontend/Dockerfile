# 빌드 단계
FROM node:18-alpine as build
WORKDIR /app

# 프로젝트 의존성 설치
COPY package*.json ./
RUN npm install

# 환경 변수 ARG로 정의
ARG REACT_APP_API_URL
ARG REACT_APP_FRONT_URL
ARG REACT_APP_KAKAO_REST_API_KEY
ARG REACT_APP_KAKAO_CLIENT_SECRET
ARG REACT_APP_KAKAO_REDIRECT_URI
ARG REACT_APP_TOSS_CLIENT_KEY
ARG REACT_APP_TOSS_CUSTOMER_KEY

# 환경 변수 로그 출력 (디버깅용)
RUN echo "REACT_APP_API_URL=$REACT_APP_API_URL" && \
    echo "REACT_APP_FRONT_URL=$REACT_APP_FRONT_URL" && \
    echo "REACT_APP_KAKAO_REST_API_KEY=$REACT_APP_KAKAO_REST_API_KEY" && \
    echo "REACT_APP_KAKAO_CLIENT_SECRET=$REACT_APP_KAKAO_CLIENT_SECRET" && \
    echo "REACT_APP_KAKAO_REDIRECT_URI=$REACT_APP_KAKAO_REDIRECT_URI" && \
    echo "REACT_APP_TOSS_CLIENT_KEY=$REACT_APP_TOSS_CLIENT_KEY" && \
    echo "REACT_APP_TOSS_CUSTOMER_KEY=$REACT_APP_TOSS_CUSTOMER_KEY"

# 프로젝트 파일 복사 및 빌드
COPY . .
RUN REACT_APP_API_URL=$REACT_APP_API_URL \
    REACT_APP_FRONT_URL=$REACT_APP_FRONT_URL \
    REACT_APP_KAKAO_REST_API_KEY=$REACT_APP_KAKAO_REST_API_KEY \
    REACT_APP_KAKAO_CLIENT_SECRET=$REACT_APP_KAKAO_CLIENT_SECRET \
    REACT_APP_KAKAO_REDIRECT_URI=$REACT_APP_KAKAO_REDIRECT_URI \
    REACT_APP_TOSS_CLIENT_KEY=$REACT_APP_TOSS_CLIENT_KEY \
    REACT_APP_TOSS_CUSTOMER_KEY=$REACT_APP_TOSS_CUSTOMER_KEY \
    npm run build

# 실행 단계
FROM node:18-alpine
WORKDIR /app

# 빌드된 파일 복사
COPY --from=build /app/build /app/build

# 실행 시 환경 변수 전달 (디버깅용)
RUN echo "RUNNING WITH REACT_APP_API_URL=$REACT_APP_API_URL" && \
    echo "RUNNING WITH REACT_APP_FRONT_URL=$REACT_APP_FRONT_URL" && \
    echo "RUNNING WITH REACT_APP_KAKAO_REST_API_KEY=$REACT_APP_KAKAO_REST_API_KEY" && \
    echo "RUNNING WITH REACT_APP_KAKAO_CLIENT_SECRET=$REACT_APP_KAKAO_CLIENT_SECRET" && \
    echo "RUNNING WITH REACT_APP_KAKAO_REDIRECT_URI=$REACT_APP_KAKAO_REDIRECT_URI" && \
    echo "RUNNING WITH REACT_APP_TOSS_CLIENT_KEY=$REACT_APP_TOSS_CLIENT_KEY" && \
    echo "RUNNING WITH REACT_APP_TOSS_CUSTOMER_KEY=$REACT_APP_TOSS_CUSTOMER_KEY"

# 실행 시 환경 변수 전달
ENV REACT_APP_API_URL=$REACT_APP_API_URL
ENV REACT_APP_FRONT_URL=$REACT_APP_FRONT_URL
ENV REACT_APP_KAKAO_REST_API_KEY=$REACT_APP_KAKAO_REST_API_KEY
ENV REACT_APP_KAKAO_CLIENT_SECRET=$REACT_APP_KAKAO_CLIENT_SECRET
ENV REACT_APP_KAKAO_REDIRECT_URI=$REACT_APP_KAKAO_REDIRECT_URI
ENV REACT_APP_TOSS_CLIENT_KEY=$REACT_APP_TOSS_CLIENT_KEY
ENV REACT_APP_TOSS_CUSTOMER_KEY=$REACT_APP_TOSS_CUSTOMER_KEY

EXPOSE 80
CMD ["npx", "serve", "-s", "build", "-l", "80"]
